# RaceControl – Konfiguration für Linux-Timing-Clients
#
# Kopieren nach .env und Werte eintragen:
#   cp .env.example .env
#
# Den aktuellen Key anzeigen:
#   python ../backend/rotate_timing_key.py --show
#
# Key automatisch in alle Clients schreiben:
#   python ../backend/rotate_timing_key.py --patch-clients

# Timing-API-Key (aus RaceControl Admin → System → Lichtschranken-Schlüssel)
TIMING_API_KEY=

# Backend-URL (nur ändern wenn RaceControl nicht auf localhost läuft)
BACKEND_WS=ws://localhost:1980/ws/timing

# ALGE Timy Multi-Client – COM-Ports der einzelnen Timy-Geräte
# Windows: COM3, COM4 usw.   Linux: /dev/ttyUSB0, /dev/ttyUSB1
# TIMY_START_PORT=COM3
# TIMY_FINISH_PORT=COM4
# TIMY_START_BAUD=9600
# TIMY_FINISH_BAUD=9600
