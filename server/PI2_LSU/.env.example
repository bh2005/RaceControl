# RaceControl Pro – LSU200 Client Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.
# Datei liegt auf dem Pi unter: /home/pi/lsu200/.env

# WebSocket-URL des RaceControl-Backends (IP des Servers am Veranstaltungstag)
# Beispiel: ws://192.168.1.100:1980/ws/timing
BACKEND_WS=ws://192.168.1.100:1980/ws/timing

# Timing-API-Key
# Quelle: RaceControl Admin → System → Lichtschranken-Schlüssel
# (wird von setup_linux.sh automatisch eingetragen wenn Backend erreichbar)
TIMING_API_KEY=
